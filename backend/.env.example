# Server
PORT=3001
NODE_ENV=development

# MongoDB Atlas connection string (use Database → Connect → Drivers)
# Include a database name before the query string, e.g. ...mongodb.net/mentora?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/mentora?retryWrites=true&w=majority

# JWT secret for app sessions (desktop + web)
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth — use the SAME client ID everywhere (marketing site, backend, desktop app)
GOOGLE_CLIENT_ID=680810171254-10q6me7giljm2v8hh17q0pg3hjgu1hkh.apps.googleusercontent.com
# Required for desktop app browser sign-in (authorization code exchange)
GOOGLE_CLIENT_SECRET=your-client-secret
# Desktop app redirect URI — add this EXACT URI in Google Cloud Console:
# http://127.0.0.1:38473/oauth/callback

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_...
# From Stripe CLI when running: npm run stripe:listen
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Local Stripe subscription testing ---
# 1. Install CLI: https://stripe.com/docs/stripe-cli#install
# 2. stripe login
# 3. Terminal A: npm run dev
# 4. Terminal B: npm run stripe:listen
# 5. Copy whsec_... from CLI output into STRIPE_WEBHOOK_SECRET above
# 6. Enable INR + Subscriptions in Stripe Dashboard (Settings → Payments)

# Public marketing site URL (checkout redirects + Stripe portal return)
SITE_URL=https://mentora-marketing-eta.vercel.app

# Comma-separated allowed browser origins for CORS
CORS_ORIGINS=https://mentora-marketing-eta.vercel.app,http://localhost:5173,http://localhost:5174,tauri://localhost,https://tauri.localhost

# Render: set Root Directory = backend, Build = npm install && npm run build, Start = npm start
# Do NOT use "npm run dev" or "npn" on Render — use "npm start" after build.

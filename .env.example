# Public site URL used for canonical links, Open Graph, sitemap, and robots.txt
VITE_SITE_URL=https://mentora-marketing-eta.vercel.app

# Backend API
# Local dev: use localhost (Vite proxies /api to :3001 when unset in dev)
# Production (Vercel): https://mentora-marketing-backend.onrender.com
VITE_API_URL=http://localhost:3001

# Google OAuth 2.0 Web Client ID (Google Cloud Console)
# Authorized JavaScript origins:
#   http://localhost:5173  (marketing site)
#   http://localhost:5174  (desktop app dev)
# Authorized redirect URIs (for desktop sign-in):
#   http://127.0.0.1:38473/oauth/callback
VITE_GOOGLE_CLIENT_ID=680810171254-10q6me7giljm2v8hh17q0pg3hjgu1hkh.apps.googleusercontent.com

# Do NOT add client secret with VITE_ prefix — it would be exposed in the browser bundle.
# Our Google Sign-In button only needs the Client ID above.

# Public site URL used for canonical links, Open Graph, sitemap, and robots.txt
VITE_SITE_URL=https://mentora-marketing-eta.vercel.app

# Google OAuth 2.0 Web Client ID (Google Cloud Console)
# Authorized origins: http://localhost:5173 and your production domain
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Do NOT add client secret with VITE_ prefix — it would be exposed in the browser bundle.
# Our Google Sign-In button only needs the Client ID above.
